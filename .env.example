# Environment Variables for GreenOps Autopilot

# Electricity Maps API (https://api.electricitymap.org)
# Get your key at https://api.electricitymap.org/
# Falls back to static carbon intensity data if not set
ELECTRICITY_MAPS_API_KEY=your_electricity_maps_key_here

# Google Gemini API — uses gemini-2.0-flash (https://ai.google.dev/)
# Get your key at https://aistudio.google.com/
# Falls back to a hardcoded explanation object if not set
GEMINI_API_KEY=your_gemini_api_key_here
